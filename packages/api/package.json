{
  "name": "@jawwing/api",
  "version": "0.1.0",
  "description": "Shared API utilities for Jawwing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./geo": {
      "import": "./dist/geo.js",
      "types": "./dist/geo.d.ts"
    },
    "./feed": {
      "import": "./dist/feed.js",
      "types": "./dist/feed.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.js",
      "types": "./dist/middleware.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "h3-js": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
