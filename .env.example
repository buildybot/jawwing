# Jawwing Environment Variables
# Copy this file to .env.local and fill in your values

# Database (Turso)
TURSO_DATABASE_URL=your_turso_database_url
TURSO_AUTH_TOKEN=your_turso_auth_token

# AI Moderation (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars

# Privacy hashing salts (generate random strings)
EMAIL_HASH_SALT=your_email_hash_salt
PHONE_HASH_SALT=your_phone_hash_salt

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# Admin API
ADMIN_API_KEY=your_admin_api_key

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Jawwing
