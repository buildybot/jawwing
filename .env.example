# Jawwing Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local or .env — only .env.example

# === Database (Turso) ===
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# === Auth ===
JWT_SECRET=generate-a-strong-random-string-here
EMAIL_HASH_SALT=generate-a-different-random-string-here

# === AI Moderation (Google Gemini) ===
GEMINI_API_KEY=your-gemini-api-key

# === Email (Resend) ===
RESEND_API_KEY=re_your-resend-api-key

# === App Config ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Jawwing

# === Expo Mobile ===
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# === Admin Seeding API ===
# Used by admin-only routes (/api/v1/admin/*) for seeding posts, votes, and uploads.
# Generate a strong random string. NEVER commit the real value — keep it in .env.local only.
ADMIN_API_KEY=generate-a-strong-admin-key-here

# === Vercel Blob Storage ===
# Required for image uploads (including admin/upload endpoint).
# Set automatically on Vercel; add manually for local dev if needed.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
